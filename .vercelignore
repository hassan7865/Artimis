# Ignore local Python environments
.venv/
venv/
env/
__pycache__/
*.pyc

# Ignore local Node environments (Vercel will build these)
node_modules/
frontend/node_modules/

# Ignore Next.js build output
frontend/.next/
.next/

# Ignore local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore Git
.git/
.gitignore

# Ignore system files
.DS_Store

# Ignore miscellaneous
leads.db
*.log
