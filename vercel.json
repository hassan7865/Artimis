{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "rewrites": [{ "source": "/api/:path*", "destination": "/api/:path*" }],
  "functions": {
    "api/**": {
      "excludeFiles": "{.next,.git,node_modules}/**",
      "maxDuration": 60
    }
  }
}
